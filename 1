<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HabitForge вҖ” д№ жғҜжү“еҚЎиҝҪиёӘеҷЁ</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;600;700&family=DM+Mono:wght@300;400&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --bg: #faf5eb; --surface: #fff; --surface-alt: #f7f2e8;
            --border: #e8e2d6; --accent: #c06030; --accent-light: rgba(192,96,48,0.1);
            --green: #2d6a4f; --green-light: rgba(45,106,79,0.1);
            --warm: #e07a5f; --text: #2b2b2b; --text-sec: #6b6560; --text-muted: #9a9590;
            --shadow-sm: 0 1px 4px rgba(43,43,43,0.06);
            --shadow-md: 0 4px 16px rgba(43,43,43,0.08);
            --radius: 14px; --radius-sm: 10px;
        }
        body {
            font-family: 'Noto Sans SC', sans-serif;
            background: var(--bg); color: var(--text); min-height: 100vh;
        }
        body::before {
            content: ''; position: fixed; inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
            pointer-events: none; z-index: 9999;
        }
        .header {
            padding: 18px 28px; display: flex; justify-content: space-between; align-items: center;
            border-bottom: 1px solid var(--border); position: sticky; top: 0;
            background: rgba(250,245,235,0.9); backdrop-filter: blur(16px); z-index: 10;
        }
        .logo { font-family: 'Noto Serif SC', serif; font-size: 1.3rem; font-weight: 700; color: var(--accent); }
        .logo span { color: var(--green); }
        .add-btn {
            padding: 8px 18px; background: var(--accent); color: #fff; border: none;
            border-radius: 20px; font-family: 'Noto Sans SC', sans-serif; font-size: 0.82rem;
            cursor: pointer; transition: all 0.25s; font-weight: 500;
        }
        .add-btn:hover { background: #a85228; letter-spacing: 0.04em; }
        .main { max-width: 860px; margin: 0 auto; padding: 28px 24px 60px; }
        .section-title {
            font-family: 'Noto Serif SC', serif; font-size: 1rem; font-weight: 600;
            margin-bottom: 16px; color: var(--text); display: flex; align-items: center; gap: 8px;
        }

        /* в”Җв”Җ Stats в”Җв”Җ */
        .stats-row { display: grid; grid-template-columns: repeat(4,1fr); gap: 14px; margin-bottom: 32px; }
        .stat-card {
            background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius);
            padding: 18px; text-align: center; box-shadow: var(--shadow-sm);
            opacity: 0; animation: fadeUp 0.5s ease forwards;
        }
        .stat-card:nth-child(1) { animation-delay: 0.05s; }
        .stat-card:nth-child(2) { animation-delay: 0.1s; }
        .stat-card:nth-child(3) { animation-delay: 0.15s; }
        .stat-card:nth-child(4) { animation-delay: 0.2s; }
        @keyframes fadeUp { from { opacity:0; transform:translateY(16px); } to { opacity:1; transform:translateY(0); } }
        .sc-val { font-family: 'DM Mono', monospace; font-size: 1.8rem; font-weight: 400; color: var(--accent); line-height: 1; }
        .sc-lbl { font-size: 0.72rem; color: var(--text-muted); margin-top: 6px; letter-spacing: 0.04em; }

        /* в”Җв”Җ Habits в”Җв”Җ */
        .habits-list { display: flex; flex-direction: column; gap: 10px; margin-bottom: 36px; }
        .habit-card {
            display: flex; align-items: center; gap: 14px;
            padding: 14px 18px; background: var(--surface); border: 1.5px solid var(--border);
            border-radius: var(--radius); transition: all 0.25s; cursor: pointer; position: relative;
            opacity: 0; animation: fadeUp 0.5s ease forwards;
        }
        .habit-card:hover { border-color: rgba(192,96,48,0.3); box-shadow: var(--shadow-sm); }
        .habit-card.checked { background: var(--green-light); border-color: rgba(45,106,79,0.3); }
        .habit-card.pop { animation: pop 0.35s ease; }
        @keyframes pop { 0% { transform: scale(1); } 40% { transform: scale(1.04); } 100% { transform: scale(1); } }
        .h-emoji {
            width: 42px; height: 42px; display: flex; align-items: center; justify-content: center;
            font-size: 1.3rem; border-radius: 10px; background: var(--surface-alt); flex-shrink: 0;
        }
        .h-info { flex: 1; }
        .h-name { font-weight: 500; font-size: 0.92rem; }
        .h-streak { font-size: 0.78rem; color: var(--text-muted); margin-top: 2px; }
        .h-streak .fire { color: var(--warm); }
        .h-check {
            width: 30px; height: 30px; border-radius: 50%; border: 2px solid var(--border);
            display: flex; align-items: center; justify-content: center; transition: all 0.3s;
            font-size: 0.85rem; flex-shrink: 0; color: transparent;
        }
        .habit-card.checked .h-check { background: var(--green); border-color: var(--green); color: #fff; transform: scale(1.1); }
        .h-del {
            display: none; position: absolute; top: 8px; right: 10px; background: none; border: none;
            color: var(--text-muted); font-size: 0.85rem; cursor: pointer; padding: 2px 6px; border-radius: 4px;
        }
        .habit-card:hover .h-del { display: block; }
        .h-del:hover { color: var(--warm); background: rgba(224,122,95,0.1); }
        .empty-habits {
            text-align: center; padding: 40px; color: var(--text-muted); font-size: 0.88rem;
            border: 2px dashed var(--border); border-radius: var(--radius);
        }

        /* в”Җв”Җ Heatmap в”Җв”Җ */
        .heatmap-section { margin-bottom: 32px; }
        .hm-wrapper { overflow-x: auto; padding-bottom: 6px; }
        .hm-container { display: inline-flex; gap: 6px; }
        .hm-days {
            display: grid; grid-template-rows: repeat(7,13px); gap: 3px;
            font-size: 0.6rem; color: var(--text-muted); align-items: center; padding-right: 4px;
        }
        .hm-grid {
            display: grid; grid-template-rows: repeat(7,13px);
            grid-auto-flow: column; grid-auto-columns: 13px; gap: 3px;
        }
        .hm-cell {
            width: 13px; height: 13px; border-radius: 3px; background: #ebedf0;
            transition: all 0.2s; cursor: default; position: relative;
        }
        .hm-cell.l1 { background: #fde0c0; }
        .hm-cell.l2 { background: #f5b87a; }
        .hm-cell.l3 { background: #e89050; }
        .hm-cell.l4 { background: #c06030; }
        .hm-cell.today { outline: 2px solid var(--accent); outline-offset: 1px; }
        .hm-cell[data-tip]:hover::after {
            content: attr(data-tip); position: absolute; bottom: calc(100% + 6px); left: 50%;
            transform: translateX(-50%); padding: 4px 8px; background: #333; color: #fff;
            font-size: 0.65rem; border-radius: 4px; white-space: nowrap; z-index: 5;
        }
        .hm-months { position: relative; height: 18px; margin-bottom: 4px; margin-left: 30px; }
        .hm-month { position: absolute; font-size: 0.6rem; color: var(--text-muted); top: 0; }
        .hm-legend { display: flex; align-items: center; gap: 4px; margin-top: 10px; font-size: 0.68rem; color: var(--text-muted); justify-content: flex-end; }
        .hm-legend .hm-cell { cursor: default; }
        .hm-legend .hm-cell:hover::after { display: none; }

        /* в”Җв”Җ Modal в”Җв”Җ */
        .modal-overlay {
            position: fixed; inset: 0; background: rgba(43,43,43,0.4);
            display: none; align-items: center; justify-content: center; z-index: 100;
            backdrop-filter: blur(4px);
        }
        .modal-overlay.show { display: flex; }
        .modal {
            background: var(--surface); border-radius: var(--radius); padding: 28px;
            width: 90%; max-width: 400px; box-shadow: var(--shadow-md);
            animation: fadeUp 0.3s ease;
        }
        .modal h3 { font-family: 'Noto Serif SC', serif; font-size: 1.1rem; margin-bottom: 20px; }
        .form-group { margin-bottom: 16px; }
        .form-group label { display: block; font-size: 0.78rem; color: var(--text-muted); margin-bottom: 6px; font-weight: 500; }
        .form-group input {
            width: 100%; padding: 10px 14px; border: 1.5px solid var(--border);
            border-radius: var(--radius-sm); font-family: 'Noto Sans SC', sans-serif;
            font-size: 0.9rem; background: var(--surface-alt); color: var(--text); outline: none;
        }
        .form-group input:focus { border-color: var(--accent); }
        .emoji-grid { display: grid; grid-template-columns: repeat(8,1fr); gap: 6px; }
        .emoji-btn {
            aspect-ratio: 1; border: 2px solid var(--border); border-radius: 8px;
            background: var(--surface-alt); font-size: 1.2rem; cursor: pointer;
            transition: all 0.2s; display: flex; align-items: center; justify-content: center;
        }
        .emoji-btn:hover, .emoji-btn.active { border-color: var(--accent); background: var(--accent-light); transform: scale(1.1); }
        .modal-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 20px; }
        .modal-actions button {
            padding: 10px 22px; border-radius: 20px; font-family: 'Noto Sans SC', sans-serif;
            font-size: 0.85rem; cursor: pointer; transition: all 0.2s; border: none;
        }
        .btn-cancel { background: var(--surface-alt); color: var(--text-sec); border: 1px solid var(--border); }
        .btn-confirm { background: var(--accent); color: #fff; }
        .btn-confirm:hover { background: #a85228; }

        /* в”Җв”Җ Congrats в”Җв”Җ */
        .congrats {
            text-align: center; padding: 20px; background: var(--green-light);
            border: 1.5px solid rgba(45,106,79,0.2); border-radius: var(--radius);
            margin-bottom: 24px; display: none; font-size: 0.95rem; color: var(--green);
            animation: fadeUp 0.4s ease;
        }
        .congrats.show { display: block; }

        @media (max-width: 600px) {
            .stats-row { grid-template-columns: repeat(2,1fr); }
            .main { padding: 20px 16px 48px; }
            .header { padding: 14px 16px; }
            .sc-val { font-size: 1.4rem; }
            .emoji-grid { grid-template-columns: repeat(6,1fr); }
        }
    </style>
</head>
<body>
    <header class="header">
        <div class="logo">Habit<span>Forge</span></div>
        <button class="add-btn" onclick="openModal()">+ ж–°д№ жғҜ</button>
    </header>
    <main class="main">
        <div class="stats-row" id="statsRow"></div>
        <div class="congrats" id="congrats">рҹҺү еӨӘжЈ’дәҶпјҒд»Ҡж—ҘжүҖжңүд№ жғҜе·Іе…ЁйғЁе®ҢжҲҗпјҒ</div>
        <div class="section-title">рҹ“Ӣ д»Ҡж—Ҙжү“еҚЎ</div>
        <div class="habits-list" id="habitsList"></div>
        <div class="heatmap-section">
            <div class="section-title">рҹ“Ҡ жү“еҚЎзғӯеҠӣеӣҫ</div>
            <div class="hm-months" id="hmMonths"></div>
            <div class="hm-wrapper">
                <div class="hm-container">
                    <div class="hm-days"><span></span><span>дёҖ</span><span></span><span>дёү</span><span></span><span>дә”</span><span></span></div>
                    <div class="hm-grid" id="hmGrid"></div>
                </div>
            </div>
            <div class="hm-legend">
                е°‘
                <div class="hm-cell"></div>
                <div class="hm-cell l1"></div>
                <div class="hm-cell l2"></div>
                <div class="hm-cell l3"></div>
                <div class="hm-cell l4"></div>
                еӨҡ
            </div>
        </div>
    </main>
    <div class="modal-overlay" id="modalOverlay" onclick="closeModal(event)">
        <div class="modal" onclick="event.stopPropagation()">
            <h3>ж·»еҠ ж–°д№ жғҜ</h3>
            <div class="form-group">
                <label>д№ жғҜеҗҚз§°</label>
                <input type="text" id="newName" placeholder="еҰӮпјҡжҜҸж—ҘиҝҗеҠЁ" maxlength="20">
            </div>
            <div class="form-group">
                <label>йҖүжӢ©еӣҫж Ү</label>
                <div class="emoji-grid" id="emojiGrid"></div>
            </div>
            <div class="modal-actions">
                <button class="btn-cancel" onclick="closeModal()">еҸ–ж¶Ҳ</button>
                <button class="btn-confirm" onclick="addHabit()">зЎ®е®ҡж·»еҠ </button>
            </div>
        </div>
    </div>
    <script>
        const EMOJIS = ['рҹҸғ','рҹ“ҡ','рҹ’§','рҹ§ҳ','рҹ’Ә','рҹҘ—','рҹҳҙ','рҹҺө','вңҚпёҸ','рҹ§№','рҹ’Ҡ','рҹҢҝ','вҳҖпёҸ','рҹҺҜ','рҹ§ ','вқӨпёҸ','рҹҸӢпёҸ','рҹҡҙ','рҹҚҺ','рҹ«Ғ','рҹҰ·','рҹӣҢ','рҹ§№','рҹҺҜ'];
        const MONTHS = ['1жңҲ','2жңҲ','3жңҲ','4жңҲ','5жңҲ','6жңҲ','7жңҲ','8жңҲ','9жңҲ','10жңҲ','11жңҲ','12жңҲ'];
        const NUM_WEEKS = 26;

        let habits = [], checkins = {}, selectedEmoji = 'рҹҸғ';

        /* в”Җв”Җ Helpers в”Җв”Җ */
        function fmtDate(d) { return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`; }
        const today = () => fmtDate(new Date());
        function uid() { return 'h' + Date.now().toString(36) + Math.random().toString(36).slice(2,5); }

        /* в”Җв”Җ Init в”Җв”Җ */
        function init() {
            loadState();
            if (!habits.length) {
                habits = [
                    { id: uid(), name: 'жҜҸж—ҘиҝҗеҠЁ', emoji: 'рҹҸғ', created: today() },
                    { id: uid(), name: 'йҳ…иҜ»30еҲҶ', emoji: 'рҹ“ҡ', created: today() },
                    { id: uid(), name: 'е–қеӨҹ8жқҜж°ҙ', emoji: 'рҹ’§', created: today() },
                ];
                saveState();
            }
            renderEmojiGrid();
            renderAll();
        }

        /* в”Җв”Җ Emoji Grid в”Җв”Җ */
        function renderEmojiGrid() {
            document.getElementById('emojiGrid').innerHTML = EMOJIS.map(e =>
                `<button class="emoji-btn ${e===selectedEmoji?'active':''}" onclick="pickEmoji('${e}')">${e}</button>`
            ).join('');
        }
        function pickEmoji(e) {
            selectedEmoji = e;
            document.querySelectorAll('.emoji-btn').forEach(b => b.classList.toggle('active', b.textContent === e));
        }

        /* в”Җв”Җ Modal в”Җв”Җ */
        function openModal() { document.getElementById('modalOverlay').classList.add('show'); document.getElementById('newName').value = ''; document.getElementById('newName').focus(); }
        function closeModal(e) { if (!e || e.target === document.getElementById('modalOverlay')) document.getElementById('modalOverlay').classList.remove('show'); }
        function addHabit() {
            const name = document.getElementById('newName').value.trim();
            if (!name) return;
            habits.push({ id: uid(), name, emoji: selectedEmoji, created: today() });
            saveState(); closeModal(); renderAll();
        }
        function deleteHabit(id) {
            habits = habits.filter(h => h.id !== id);
            Object.keys(checkins).forEach(d => { checkins[d] = (checkins[d]||[]).filter(i => i !== id); });
            saveState(); renderAll();
        }

        /* в”Җв”Җ Check-in в”Җв”Җ */
        function toggle(id) {
            const td = today();
            if (!checkins[td]) checkins[td] = [];
            const idx = checkins[td].indexOf(id);
            if (idx >= 0) checkins[td].splice(idx, 1); else checkins[td].push(id);
            saveState(); renderAll();
        }
        function isChecked(id) { return (checkins[today()] || []).includes(id); }
        function getStreak(id) {
            let s = 0, d = new Date();
            while (true) {
                const ds = fmtDate(d);
                if ((checkins[ds] || []).includes(id)) { s++; d.setDate(d.getDate() - 1); } else break;
            }
            return s;
        }

        /* в”Җв”Җ Stats в”Җв”Җ */
        function getTodayDone() { return (checkins[today()] || []).length; }
        function getWeekRate() {
            const now = new Date(), ws = new Date(now);
            ws.setDate(ws.getDate() - (now.getDay() || 7) + 1);
            let possible = 0, done = 0;
            for (let i = 0; i < 7; i++) {
                const d = new Date(ws); d.setDate(d.getDate() + i);
                if (d > now) break;
                possible += habits.length;
                done += (checkins[fmtDate(d)] || []).length;
            }
            return possible ? Math.round(done / possible * 100) : 0;
        }
        function getTotalCheckins() { return Object.values(checkins).reduce((s, a) => s + a.length, 0); }
        function getBestStreak() {
            let best = 0, cur = 0, d = new Date();
            for (let i = 0; i < 365; i++) {
                const ds = fmtDate(d);
                if ((checkins[ds] || []).length > 0) { cur++; best = Math.max(best, cur); } else cur = 0;
                d.setDate(d.getDate() - 1);
            }
            return best;
        }

        /* в”Җв”Җ Render All в”Җв”Җ */
        function renderAll() { renderStats(); renderHabits(); renderHeatmap(); checkCongrats(); }

        function renderStats() {
            const data = [
                { val: `${getTodayDone()}/${habits.length}`, lbl: 'д»Ҡж—Ҙе®ҢжҲҗ' },
                { val: getWeekRate() + '%', lbl: 'жң¬е‘Ёе®ҢжҲҗзҺҮ' },
                { val: getBestStreak(), lbl: 'жңҖдҪіиҝһз»ӯеӨ©ж•°' },
                { val: getTotalCheckins(), lbl: 'жҖ»жү“еҚЎж¬Ўж•°' },
            ];
            document.getElementById('statsRow').innerHTML = data.map((d, i) =>
                `<div class="stat-card" style="animation-delay:${i*0.05}s"><div class="sc-val">${d.val}</div><div class="sc-lbl">${d.lbl}</div></div>`
            ).join('');
        }

        function renderHabits() {
            const el = document.getElementById('habitsList');
            if (!habits.length) { el.innerHTML = '<div class="empty-habits">зӮ№еҮ»еҸідёҠи§’гҖҢ+ ж–°д№ жғҜгҖҚејҖе§ӢиҝҪиёӘ</div>'; return; }
            el.innerHTML = habits.map((h, i) => {
                const checked = isChecked(h.id), streak = getStreak(h.id);
                return `<div class="habit-card ${checked?'checked':''}" style="animation-delay:${i*0.06}s" onclick="toggleCard('${h.id}',this)">
                    <div class="h-emoji">${h.emoji}</div>
                    <div class="h-info">
                        <div class="h-name">${h.name}</div>
                        <div class="h-streak"><span class="fire">рҹ”Ҙ</span> иҝһз»ӯ ${streak} еӨ©</div>
                    </div>
                    <div class="h-check">${checked?'вң“':''}</div>
                    <button class="h-del" onclick="event.stopPropagation();deleteHabit('${h.id}')" title="еҲ йҷӨ">Г—</button>
                </div>`;
            }).join('');
        }

        function toggleCard(id, el) {
            toggle(id);
            el.classList.add('pop');
            setTimeout(() => el.classList.remove('pop'), 350);
        }

        function checkCongrats() {
            const el = document.getElementById('congrats');
            el.classList.toggle('show', habits.length > 0 && getTodayDone() === habits.length);
        }

        /* в”Җв”Җ Heatmap в”Җв”Җ */
        function renderHeatmap() {
            const now = new Date();
            const start = new Date(now);
            start.setDate(start.getDate() - (NUM_WEEKS * 7 - 1) - now.getDay());

            const grid = document.getElementById('hmGrid');
            const monthEl = document.getElementById('hmMonths');
            let cells = '', curMonth = -1, monthHtml = '', weekIdx = 0;
            const d = new Date(start);
            const cellW = 13 + 3;

            while (d <= now) {
                const ds = fmtDate(d);
                const count = (checkins[ds] || []).length;
                const maxH = Math.max(habits.length, 1);
                let lv = 0;
                if (count > 0) lv = Math.min(4, Math.ceil(count / maxH * 4));
                const isToday = ds === today();
                const dayNames = ['ж—Ҙ','дёҖ','дәҢ','дёү','еӣӣ','дә”','е…ӯ'];
                cells += `<div class="hm-cell l${lv} ${isToday?'today':''}" data-tip="${ds} ${dayNames[d.getDay()]}: ${count}/${maxH}"></div>`;

                if (d.getDay() === 0 || d.getTime() === start.getTime()) {
                    if (d.getMonth() !== curMonth) {
                        curMonth = d.getMonth();
                        monthHtml += `<span class="hm-month" style="left:${weekIdx * cellW}px">${MONTHS[curMonth]}</span>`;
                    }
                    if (d.getTime() !== start.getTime()) weekIdx++;
                }
                d.setDate(d.getDate() + 1);
            }
            grid.innerHTML = cells;
            monthEl.innerHTML = monthHtml;
        }

        /* в”Җв”Җ Persistence в”Җв”Җ */
        function saveState() { localStorage.setItem('habitforge', JSON.stringify({ habits, checkins })); }
        function loadState() {
            try {
                const d = JSON.parse(localStorage.getItem('habitforge'));
                if (d) { habits = d.habits || []; checkins = d.checkins || {}; }
            } catch(e) {}
        }

        init();
    </script>
</body>
</html>
